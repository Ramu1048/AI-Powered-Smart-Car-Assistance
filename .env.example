# Unified Database Connection (PostgreSQL or local SQLite fallback)
DATABASE_URL=sqlite:///./smart_car_db.db

# LLM Conversational Assistant & Embedding Generator Keys
GEMINI_API_KEY=your_google_gemini_api_key_here

# YouTube Data API v3 Credentials (for scraping reviews)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# JWT Authentication secret key
JWT_SECRET=your_jwt_signing_secret_here

# Google Maps Javascript SDK Key (for map integrations)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
